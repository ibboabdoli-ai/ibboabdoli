<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Feedback Form – Ibbo Abdoli</title>
  <link rel="stylesheet" href="assets/vendor/bootstrap-icons/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --background: #000;
      --container-bg: #0a0a0a;
      --primary: #ffffff;
      --secondary: #888;
      --accent: #0071e3;
      --input-bg: #1c1c1e;
      --input-border: #333;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;
      background-color: var(--background);
      color: var(--primary);
      line-height: 1.6;
    }

    header {
      border-bottom: 1px solid #1c1c1e;
      background-color: var(--background);
      padding: 20px 0;
    }

    #navbar {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    #navbar ul {
      display: flex;
      list-style: none;
      gap: 32px;
    }

    #navbar ul li a {
      color: var(--primary);
      text-decoration: none;
      font-weight: 500;
      font-size: 15px;
      padding: 4px 8px;
    }

    #navbar ul li a:hover {
      color: var(--accent);
      border-bottom: 1px solid var(--accent);
    }

    .container {
      max-width: 560px;
      margin: 80px auto;
      padding: 40px;
      background-color: var(--container-bg);
      border-radius: 20px;
      box-shadow: 0 10px 60px rgba(0,0,0,0.6);
    }

    h1 {
      font-size: 28px;
      text-align: center;
      margin-bottom: 32px;
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-size: 14px;
      color: var(--secondary);
    }

    input, textarea {
      width: 100%;
      padding: 14px;
      border-radius: 12px;
      border: 1px solid var(--input-border);
      background-color: var(--input-bg);
      color: var(--primary);
      font-size: 15px;
      margin-bottom: 24px;
    }

    input::placeholder,
    textarea::placeholder {
      color: var(--secondary);
    }

    button {
      width: 100%;
      padding: 14px;
      background-color: var(--accent);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.3s;
    }

    button:hover {
      background-color: #005bb5;
    }

    .success-message {
      text-align: center;
      display: none;
      margin-top: 32px;
    }

    .success-message h2 {
      color: var(--accent);
      font-size: 22px;
      margin-bottom: 12px;
    }

    .footer {
      text-align: center;
      font-size: 14px;
      color: var(--secondary);
      margin-top: 40px;
    }

    .footer a {
      color: var(--accent);
      text-decoration: none;
    }

    @media (max-width: 600px) {
      .container {
        margin: 40px 16px;
        padding: 24px;
      }

      #navbar ul {
        flex-direction: column;
        gap: 12px;
      }
    }
  </style>
</head>
<body>
  <header>
    <nav id="navbar">
      <ul>
        <li><a href="index.html">Home</a></li>
        <li><a href="index.html#linkedin-posts">LinkedIn</a></li>
        <li><a href="index.html#about">About</a></li>
        <li><a href="index.html#resume">Resume</a></li>
        <li><a href="index.html#services">Services</a></li>
        <li><a href="index.html#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <main class="container">
    <h1>Share Your Feedback</h1>
    <form id="orderForm">
      <label for="name">Full Name</label>
      <input type="text" id="name" name="name" placeholder="e.g. Alexander Anderson" required />

      <label for="email">Email</label>
      <input type="email" id="email" name="email" placeholder="e.g. alex@email.com" required />

      <label for="orderPurpose">Your Message</label>
      <textarea id="orderPurpose" name="orderPurpose" rows="5" placeholder="e.g. I have a feature suggestion or concern..." required></textarea>

      <button type="submit">Send Feedback</button>
    </form>

    <div class="success-message" id="successMessage">
      <h2>✅ Thank you!</h2>
      <p>We appreciate your message and will be in touch if needed.</p>
    </div>

    <div class="footer">
      <p>Need help? <a href="mailto:ibbo.abdoli@gmail.com">Contact Support</a></p>
    </div>
  </main>

  <script>
    const form = document.getElementById('orderForm');
    const successMessage = document.getElementById('successMessage');

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const formData = new FormData(form);

      try {
        const response = await fetch('https://formspree.io/f/xzzvkevw', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: formData
        });

        if (response.ok) {
          form.style.display = 'none';
          successMessage.style.display = 'block';
        } else {
          alert('Something went wrong. Please try again.');
        }
      } catch (error) {
        alert('There was an error submitting the form.');
      }
    });
  </script>
</body>
</html>
